<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>

<uranium:UraniumContentPage
    Title="设置"
    x:Class="Lunadroid.App.Views.SettingsPage"
    x:DataType="vm:SettingsViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:materialSymbols="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:vm="clr-namespace:Lunadroid.App.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="16,12" Spacing="8">

            <!--  云端资源拉取  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                  Dark={StaticResource Gray900}}"
                Padding="16,12"
                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                         Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="📡 资源管理"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                    Dark={StaticResource White}}" />

                    <Grid
                        ColumnDefinitions="*,Auto"
                        ColumnSpacing="8"
                        RowDefinitions="Auto,Auto">
                        <Label
                            FontSize="13"
                            Grid.Column="0"
                            Grid.Row="0"
                            Text="云端资源地址"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                        Dark={StaticResource Gray400}}" />
                        <Entry
                            FontSize="13"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Grid.Row="1"
                            Placeholder="请输入云端资源地址"
                            Text="{Binding CloudSourceUrl}" />
                    </Grid>

                    <Button
                        Command="{Binding FetchSourcesFromCloudCommand}"
                        HorizontalOptions="Fill"
                        IsEnabled="{Binding IsFetchingSources, Converter={StaticResource InvertedBoolConverter}}"
                        Text="从云端拉取资源" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button
                            BackgroundColor="{AppThemeBinding Light={StaticResource Secondary},
                                                              Dark={StaticResource SecondaryDark}}"
                            Command="{Binding ImportSourcesFromJsonCommand}"
                            Grid.Column="0"
                            IsEnabled="{Binding IsImporting, Converter={StaticResource InvertedBoolConverter}}"
                            Text="导入JSON" />
                        <Button
                            BackgroundColor="{AppThemeBinding Light={StaticResource Secondary},
                                                              Dark={StaticResource SecondaryDark}}"
                            Command="{Binding ExportSourcesToJsonCommand}"
                            Grid.Column="1"
                            IsEnabled="{Binding IsExporting, Converter={StaticResource InvertedBoolConverter}}"
                            Text="导出JSON" />
                    </Grid>

                    <Label
                        FontSize="12"
                        Text="{Binding FetchStatusText}"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                    Dark={StaticResource Gray400}}" />
                </VerticalStackLayout>
            </Border>

            <!--  ApiSource 列表  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                  Dark={StaticResource Gray900}}"
                Padding="16,12"
                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                         Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="8">
                    <uranium:ExpanderView IsExpanded="False">
                        <uranium:ExpanderView.Header>
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                Text="📋 资源列表"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                            Dark={StaticResource White}}" />
                        </uranium:ExpanderView.Header>
                        <CollectionView ItemsSource="{Binding ApiSourceItems}" MaximumHeightRequest="400">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ApiSourceItem">
                                    <Border
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Background},
                                                                          Dark={StaticResource Gray900}}"
                                        Margin="0,3"
                                        Padding="10,8"
                                        Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                                                 Dark={StaticResource Gray600}}"
                                        StrokeShape="RoundRectangle 8">
                                        <Grid
                                            ColumnDefinitions="Auto,*,Auto,Auto"
                                            ColumnSpacing="8"
                                            RowDefinitions="Auto,Auto">
                                            <Switch
                                                Grid.Column="0"
                                                Grid.Row="0"
                                                Grid.RowSpan="2"
                                                IsToggled="{Binding Enable}"
                                                OnColor="{StaticResource Primary}"
                                                Toggled="Switch_OnToggled"
                                                VerticalOptions="Center" />
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="14"
                                                Grid.Column="1"
                                                Grid.Row="0"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding Name}"
                                                TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                                            Dark={StaticResource White}}" />
                                            <Label
                                                FontSize="11"
                                                Grid.Column="1"
                                                Grid.Row="1"
                                                LineBreakMode="MiddleTruncation"
                                                Text="{Binding Source}"
                                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                                            Dark={StaticResource Gray400}}" />
                                            <Label
                                                FontSize="14"
                                                Grid.Column="2"
                                                Grid.Row="0"
                                                IsVisible="{Binding IsCustom}"
                                                Text="自定义"
                                                VerticalOptions="Center" />
                                            <ImageButton
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SettingsViewModel}}, Path=DeleteApiSourceCommand}"
                                                CommandParameter="{Binding}"
                                                Grid.Column="3"
                                                Grid.Row="0"
                                                Grid.RowSpan="2"
                                                HeightRequest="36"
                                                Source="{FontImageSource FontFamily=MaterialOutlined,
                                                                         Size=20,
                                                                         Color={AppThemeBinding Light={StaticResource Error},
                                                                                                Dark={StaticResource ErrorDark}},
                                                                         Glyph={x:Static materialSymbols:MaterialOutlined.Delete}}"
                                                WidthRequest="36" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </uranium:ExpanderView>
                </VerticalStackLayout>
            </Border>

            <!--  Ping 测试  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                  Dark={StaticResource Gray900}}"
                Padding="16,12"
                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                         Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Grid.Column="0"
                            Text="⚡ 连通性测试"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                        Dark={StaticResource White}}" />
                        <Button
                            Command="{Binding PingAllSourcesCommand}"
                            FontSize="13"
                            Grid.Column="1"
                            HeightRequest="36"
                            IsEnabled="{Binding IsPinging, Converter={StaticResource InvertedBoolConverter}}"
                            Padding="12,6"
                            Text="开始测试" />
                    </Grid>

                    <Label
                        FontSize="12"
                        Text="{Binding PingStatusText}"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                    Dark={StaticResource Gray400}}" />

                    <ActivityIndicator
                        Color="{StaticResource Primary}"
                        HorizontalOptions="Center"
                        IsRunning="{Binding IsPinging}"
                        IsVisible="{Binding IsPinging}" />

                    <CollectionView ItemsSource="{Binding PingResults}" MaximumHeightRequest="300">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:PingResult">
                                <Border
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Background},
                                                                      Dark={StaticResource Gray900}}"
                                    Margin="0,2"
                                    Padding="10,6"
                                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                                             Dark={StaticResource Gray600}}"
                                    StrokeShape="RoundRectangle 6">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Label
                                            FontSize="13"
                                            Grid.Column="0"
                                            LineBreakMode="TailTruncation"
                                            Text="{Binding Name}"
                                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                                        Dark={StaticResource White}}" />
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="13"
                                            Grid.Column="1"
                                            Text="{Binding Status}"
                                            TextColor="{Binding StatusColor}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!--  缓存管理  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                  Dark={StaticResource Gray900}}"
                Padding="16,12"
                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                         Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Grid.Column="0"
                            Text="🗑️ 缓存管理"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                        Dark={StaticResource White}}" />
                        <Button
                            Command="{Binding LoadCacheInfoCommand}"
                            FontSize="12"
                            Grid.Column="1"
                            HeightRequest="32"
                            IsEnabled="{Binding IsCalculatingCache, Converter={StaticResource InvertedBoolConverter}}"
                            Padding="10,4"
                            Text="刷新" />
                        <Button
                            BackgroundColor="{AppThemeBinding Light={StaticResource Error},
                                                              Dark={StaticResource ErrorDark}}"
                            Command="{Binding ClearAllCacheCommand}"
                            FontSize="12"
                            Grid.Column="2"
                            HeightRequest="32"
                            IsEnabled="{Binding IsClearingCache, Converter={StaticResource InvertedBoolConverter}}"
                            Padding="10,4"
                            Text="清除全部" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label
                            FontSize="14"
                            Grid.Column="0"
                            Text="缓存占用:"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                        Dark={StaticResource Gray400}}" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Grid.Column="1"
                            Text="{Binding CacheSizeText}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                        Dark={StaticResource White}}" />
                    </Grid>

                    <ActivityIndicator
                        Color="{StaticResource Primary}"
                        HorizontalOptions="Center"
                        IsRunning="{Binding IsCalculatingCache}"
                        IsVisible="{Binding IsCalculatingCache}" />

                    <uranium:ExpanderView IsExpanded="False">
                        <uranium:ExpanderView.Header>
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="占用最大的缓存"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                            Dark={StaticResource Gray400}}" />
                        </uranium:ExpanderView.Header>
                        <CollectionView ItemsSource="{Binding CacheItems}" MaximumHeightRequest="300">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:CacheItemInfo">
                                    <Border
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Background},
                                                                          Dark={StaticResource Gray900}}"
                                        Margin="0,2"
                                        Padding="10,6"
                                        Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                                                 Dark={StaticResource Gray600}}"
                                        StrokeShape="RoundRectangle 6">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <VerticalStackLayout Grid.Column="0">
                                                <Label
                                                    FontSize="13"
                                                    LineBreakMode="MiddleTruncation"
                                                    Text="{Binding FileName}"
                                                    TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                                                Dark={StaticResource White}}" />
                                                <Label
                                                    FontSize="11"
                                                    Text="{Binding SizeText}"
                                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                                                Dark={StaticResource Gray400}}" />
                                            </VerticalStackLayout>
                                            <ImageButton
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SettingsViewModel}}, Path=DeleteCacheItemCommand}"
                                                CommandParameter="{Binding}"
                                                Grid.Column="1"
                                                HeightRequest="32"
                                                Source="{FontImageSource FontFamily=MaterialOutlined,
                                                                         Size=18,
                                                                         Color={AppThemeBinding Light={StaticResource Error},
                                                                                                Dark={StaticResource ErrorDark}},
                                                                         Glyph={x:Static materialSymbols:MaterialOutlined.Delete}}"
                                                WidthRequest="32" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </uranium:ExpanderView>
                </VerticalStackLayout>
            </Border>

            <!--  AppConfig 设置  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                  Dark={StaticResource Gray900}}"
                Padding="16,12"
                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                         Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="⚙️ 应用配置"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                    Dark={StaticResource White}}" />

                    <Grid ColumnDefinitions="*,Auto" IsEnabled="False">
                        <Label
                            FontSize="14"
                            Grid.Column="0"
                            Text="自动播放"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                        Dark={StaticResource White}}"
                            VerticalOptions="Center" />
                        <Switch
                            Grid.Column="1"
                            IsToggled="{Binding Autoplay}"
                            OnColor="{StaticResource Primary}"
                            VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            FontSize="14"
                            Grid.Column="0"
                            Text="强制使用API"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                        Dark={StaticResource White}}"
                            VerticalOptions="Center" />
                        <Switch
                            Grid.Column="1"
                            IsToggled="{Binding ForceApiNeedSpecialSource}"
                            OnColor="{StaticResource Primary}"
                            VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            FontSize="14"
                            Grid.Column="0"
                            Text="安全锁开启"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                        Dark={StaticResource White}}"
                            VerticalOptions="Center" />
                        <Switch
                            Grid.Column="1"
                            IsToggled="{Binding IsSecurityLockEnabled}"
                            OnColor="{StaticResource Primary}"
                            VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            FontSize="14"
                            Grid.Column="0"
                            Text="重置安全锁密码"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                        Dark={StaticResource White}}"
                            VerticalOptions="Center" />
                        <Button
                            Command="{Binding ResetPinCodeCommand}"
                            Grid.Column="1"
                            Text="重置" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</uranium:UraniumContentPage>
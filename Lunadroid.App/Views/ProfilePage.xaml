<?xml version="1.0" encoding="UTF-8" ?>

<uranium:UraniumContentPage
    Title="我的"
    x:Class="Lunadroid.App.Views.ProfilePage"
    x:DataType="vm:ProfileViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:materialSymbols="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:uranium="clr-namespace:UraniumUI.Pages;assembly=UraniumUI"
    xmlns:vm="clr-namespace:Lunadroid.App.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <ScrollView>
        <VerticalStackLayout Padding="16,20" Spacing="12">

            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                  Dark={StaticResource Gray900}}"
                Padding="16,12"
                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                         Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSettingsTapped" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Label
                        FontSize="24"
                        Grid.Column="0"
                        Text="⚙️"
                        VerticalOptions="Center" />
                    <Label
                        FontSize="16"
                        Grid.Column="1"
                        Text="设置"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                    Dark={StaticResource White}}"
                        VerticalOptions="Center" />
                    <Image
                        Grid.Column="2"
                        Source="{FontImageSource FontFamily=MaterialOutlined,
                                                 Size=24,
                                                 Color={AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                                        Dark={StaticResource Gray400}},
                                                 Glyph={x:Static materialSymbols:MaterialOutlined.Chevron_right}}"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                  Dark={StaticResource Gray900}}"
                Padding="16,12"
                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                         Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="🎨 外观"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                    Dark={StaticResource White}}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            FontSize="14"
                            Grid.Column="0"
                            Text="主题模式"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                        Dark={StaticResource White}}"
                            VerticalOptions="Center" />
                        <Picker
                            Grid.Column="1"
                            ItemsSource="{Binding ThemeOptions}"
                            SelectedIndex="{Binding SelectedThemeIndex}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                        Dark={StaticResource White}}"
                            VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                  Dark={StaticResource Gray900}}"
                Padding="16,12"
                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                         Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="ℹ️ 关于"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                    Dark={StaticResource White}}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            FontSize="14"
                            Grid.Column="0"
                            Text="版本号"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                        Dark={StaticResource White}}"
                            VerticalOptions="Center" />
                        <Label
                            FontSize="14"
                            Grid.Column="1"
                            Text="{Binding VersionText}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                        Dark={StaticResource Gray400}}"
                            VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            FontSize="14"
                            Grid.Column="0"
                            Text="编译日期"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                        Dark={StaticResource White}}"
                            VerticalOptions="Center" />
                        <Label
                            FontSize="14"
                            Grid.Column="1"
                            Text="{Binding BuildDateText}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                        Dark={StaticResource Gray400}}"
                            VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</uranium:UraniumContentPage>
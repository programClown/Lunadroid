<?xml version="1.0" encoding="utf-8" ?>

<uranium:UraniumContentPage
    x:Class="Lunadroid.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:Lunadroid.App.Models"
    xmlns:uranium="clr-namespace:UraniumUI.Pages;assembly=UraniumUI"
    xmlns:vm="clr-namespace:Lunadroid.App.ViewModels"
    Title="首页"
    x:DataType="vm:HomeViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <!--  Search Bar  -->
        <SearchBar
            Grid.Row="0"
            Margin="12,8"
            HeightRequest="48"
            Placeholder="搜索影视资源..."
            SearchCommand="{Binding SearchCommand}"
            Text="{Binding SearchText}" />

        <!--  Search Status & Stop Button  -->
        <HorizontalStackLayout
            Grid.Row="1"
            Margin="16,0,16,4"
            HorizontalOptions="Fill"
            Spacing="12">
            <ActivityIndicator
                HeightRequest="20"
                IsRunning="{Binding IsSearchOngoing}"
                VerticalOptions="Center"
                WidthRequest="20"
                Color="{StaticResource Primary}" />
            <Label
                FontSize="13"
                LineBreakMode="TailTruncation"
                Text="{Binding SearchStatusText}"
                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                            Dark={StaticResource Gray400}}"
                VerticalOptions="Center" />
            <Button
                Padding="8,2"
                BackgroundColor="{StaticResource Error}"
                Command="{Binding StopSearchCommand}"
                FontSize="12"
                HeightRequest="32"
                IsVisible="{Binding IsSearchOngoing}"
                Text="停止搜索"
                TextColor="White"
                VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!--  Movie Cards Grid  -->
        <CollectionView
            Grid.Row="2"
            Margin="8,4"
            IsVisible="{Binding HasSearchResults}"
            ItemSizingStrategy="MeasureFirstItem"
            ItemsLayout="VerticalGrid, 3"
            ItemsSource="{Binding SearchResults}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:VedioSearchResult">
                    <Border
                        Margin="6,4"
                        Padding="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                          Dark={StaticResource Gray900}}"
                        MaximumWidthRequest="200"
                        Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                                 Dark={StaticResource Gray600}}"
                        StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=MovieTappedCommand}" CommandParameter="{Binding}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="0">
                            <!--  Poster Image  -->
                            <Image
                                Aspect="AspectFill"
                                HeightRequest="180"
                                HorizontalOptions="Fill"
                                MinimumWidthRequest="100"
                                Source="{Binding Cover}"
                                WidthRequest="200">
                                <Image.IsVisible>
                                    <Binding Converter="{StaticResource StringIsNotNullOrEmptyConverter}" Path="Cover" />
                                </Image.IsVisible>
                            </Image>

                            <!--  Movie Info  -->
                            <VerticalStackLayout Padding="8,6" Spacing="3">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    LineBreakMode="TailTruncation"
                                    Text="{Binding Name}"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                                Dark={StaticResource White}}" />

                                <!--  Year & Category  -->
                                <Label
                                    FontSize="11"
                                    LineBreakMode="TailTruncation"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                                Dark={StaticResource Gray400}}">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0} · {1}">
                                            <Binding Path="Year" />
                                            <Binding Path="Tag" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Property="Scale" Value="1.05" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!--  Empty State  -->
        <VerticalStackLayout
            Grid.Row="2"
            Margin="0,60,0,0"
            HorizontalOptions="Center"
            IsVisible="{Binding HasSearchResults, Converter={StaticResource InvertedBoolConverter}}"
            Spacing="12"
            VerticalOptions="Center">
            <Label
                FontSize="48"
                HorizontalOptions="Center"
                Text="🎬" />
            <Label
                FontSize="16"
                HorizontalOptions="Center"
                Text="搜索影视资源开始观看"
                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                            Dark={StaticResource Gray400}}" />
            <Label
                FontSize="13"
                HorizontalOptions="Center"
                Text="点击上方搜索框输入关键词搜索"
                TextColor="{AppThemeBinding Light={StaticResource Outline},
                                            Dark={StaticResource Gray500}}" />
        </VerticalStackLayout>

    </Grid>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Command="{Binding PickLocalFileCommand}"
            Order="Primary"
            Priority="0"
            Text="本地播放" />
    </ContentPage.ToolbarItems>

</uranium:UraniumContentPage>
<?xml version="1.0" encoding="utf-8" ?>

<uranium:UraniumContentPage
    Title="播放"
    x:Class="Lunadroid.App.Views.PlayerPage"
    x:DataType="vm:PlayerViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:Lunadroid.App.Controls"
    xmlns:material="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    xmlns:uranium="clr-namespace:UraniumUI.Pages;assembly=UraniumUI"
    xmlns:vm="clr-namespace:Lunadroid.App.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid RowDefinitions="300,Auto">

        <Border
            BackgroundColor="Black"
            Grid.Row="0"
            StrokeShape="Rectangle">
            <controls:VideoPlayer
                ShouldAutoPlay="True"
                Source="{Binding VideoUrl}"
                VideoTitle="{Binding Title}" />
        </Border>

        <Grid
            Grid.Row="1"
            Margin="12,8"
            RowDefinitions="Auto,*">

            <ScrollView Grid.Row="0" Margin="0,0,0,8">
                <VerticalStackLayout Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        LineBreakMode="WordWrap"
                        Text="{Binding Title}"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                    Dark={StaticResource White}}" />

                    <HorizontalStackLayout Spacing="8">
                        <Border
                            BackgroundColor="{StaticResource PrimaryContainer}"
                            Padding="6,2"
                            StrokeShape="RoundRectangle 4">
                            <Label
                                FontSize="12"
                                Text="{Binding VideoDetail.Type}"
                                TextColor="{StaticResource OnPrimaryContainer}" />
                        </Border>

                        <Border
                            BackgroundColor="{StaticResource SecondaryContainer}"
                            Padding="6,2"
                            StrokeShape="RoundRectangle 4">
                            <Label
                                FontSize="12"
                                Text="{Binding VideoDetail.Area}"
                                TextColor="{StaticResource OnSecondaryContainer}" />
                        </Border>

                        <Border
                            BackgroundColor="{StaticResource TertiaryContainer}"
                            Padding="6,2"
                            StrokeShape="RoundRectangle 4">
                            <Label
                                FontSize="12"
                                Text="{Binding VideoDetail.Year}"
                                TextColor="{StaticResource OnTertiaryContainer}" />
                        </Border>

                        <Border
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant},
                                                              Dark={StaticResource Gray900}}"
                            Padding="6,2"
                            StrokeShape="RoundRectangle 4">
                            <Label
                                FontSize="12"
                                Text="{Binding VideoDetail.SourceName}"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                            Dark={StaticResource Gray300}}" />
                        </Border>
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <HorizontalStackLayout Spacing="4">
                            <Label
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="导演:"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                            Dark={StaticResource Gray400}}" />
                            <Label
                                FontSize="13"
                                LineBreakMode="TailTruncation"
                                Text="{Binding VideoDetail.Director}"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                            Dark={StaticResource Gray200}}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="4">
                            <Label
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="演员:"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                            Dark={StaticResource Gray400}}" />
                            <Label
                                FontSize="13"
                                LineBreakMode="TailTruncation"
                                MaxLines="2"
                                Text="{Binding VideoDetail.Actor}"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                            Dark={StaticResource Gray200}}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Label
                        FontSize="13"
                        LineBreakMode="WordWrap"
                        MaxLines="4"
                        Text="{Binding VideoDetail.Desc}"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                    Dark={StaticResource Gray400}}" />
                </VerticalStackLayout>
            </ScrollView>

            <Grid Grid.Row="1" RowDefinitions="Auto,*">
                <Label
                    FontAttributes="Bold"
                    FontSize="15"
                    Grid.Row="0"
                    Margin="0,0,0,6"
                    Text="剧集"
                    TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                Dark={StaticResource White}}" />

                <ScrollView Grid.Row="1">

                    <CollectionView
                        ItemSizingStrategy="MeasureFirstItem"
                        ItemsLayout="{OnIdiom Phone=VerticalGrid\, 3,
                                              Tablet=VerticalGrid\, 5,
                                              Desktop=VerticalGrid\, 6,
                                              TV=VerticalGrid\, 6}"
                        ItemsSource="{Binding Episodes}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:EpisodeSubjectItem">
                                <Border
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                                      Dark={StaticResource Gray900}}"
                                    Margin="4,3"
                                    Padding="8,6"
                                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                                             Dark={StaticResource Gray600}}"
                                    StrokeShape="RoundRectangle 8">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PlayerViewModel}}, Path=SelectEpisodeCommand}" CommandParameter="{Binding}" />
                                    </Border.GestureRecognizers>
                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                                        <ImageButton
                                            BackgroundColor="Transparent"
                                            Grid.Row="0"
                                            HeightRequest="24"
                                            HorizontalOptions="Center"
                                            Source="{FontImageSource FontFamily=MaterialOutlined,
                                                                     Glyph={x:Static material:MaterialOutlined.Play_circle},
                                                                     Size=18,
                                                                     Color={StaticResource Primary}}"
                                            WidthRequest="24" />
                                        <Label
                                            FontSize="12"
                                            Grid.Row="1"
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            LineBreakMode="TailTruncation"
                                            Text="{Binding Name}"
                                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                                        Dark={StaticResource White}}" />
                                    </Grid>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroupList>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal" />
                                                <VisualState x:Name="PointerOver">
                                                    <VisualState.Setters>
                                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource Gray900}}" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateGroupList>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </ScrollView>
            </Grid>

        </Grid>

    </Grid>

</uranium:UraniumContentPage>
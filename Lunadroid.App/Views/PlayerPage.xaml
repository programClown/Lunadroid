<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Lunadroid.App.Views.PlayerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:materialSyml="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:vm="clr-namespace:Lunadroid.App.ViewModels"
    Title="播放"
    x:DataType="vm:PlayerViewModel">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout
            Margin="{OnIdiom 10,
                             Phone=0}"
            Spacing="12"
            StyleClass="Elevation1">
            <uranium:Dropdown
                ItemsSource="{Binding PlaySurfaces}"
                Placeholder="Choose"
                SelectedItem="{Binding SelectedPlaySurface, Mode=TwoWay}" />

            <toolkit:MediaElement
                AndroidViewType="SurfaceView"
                HeightRequest="240"
                HorizontalOptions="Fill"
                IsVisible="{Binding IsMauiPlayer}"
                ShouldAutoPlay="True"
                ShouldShowPlaybackControls="True"
                Source="{Binding MauiVideoUrl, Mode=OneWay}" />

            <WebView
                HeightRequest="240"
                IsVisible="{Binding IsMauiPlayer, Converter={StaticResource InvertedBoolConverter}}"
                Source="{Binding WebVideoUrl, Mode=OneWay}" />
        </VerticalStackLayout>

        <Grid
            Grid.Row="1"
            Margin="12,8"
            RowDefinitions="Auto,*">

            <ScrollView Grid.Row="0" Margin="0,0,0,8">
                <VerticalStackLayout Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        LineBreakMode="WordWrap"
                        Text="{Binding VideoDetail.Title}"
                        TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                    Dark={StaticResource White}}" />

                    <HorizontalStackLayout Spacing="8">
                        <Border
                            Padding="6,2"
                            BackgroundColor="{StaticResource PrimaryContainer}"
                            StrokeShape="RoundRectangle 4">
                            <Label
                                FontSize="12"
                                Text="{Binding VideoDetail.Type}"
                                TextColor="{StaticResource OnPrimaryContainer}" />
                        </Border>

                        <Border
                            Padding="6,2"
                            BackgroundColor="{StaticResource SecondaryContainer}"
                            StrokeShape="RoundRectangle 4">
                            <Label
                                FontSize="12"
                                Text="{Binding VideoDetail.Area}"
                                TextColor="{StaticResource OnSecondaryContainer}" />
                        </Border>

                        <Border
                            Padding="6,2"
                            BackgroundColor="{StaticResource TertiaryContainer}"
                            StrokeShape="RoundRectangle 4">
                            <Label
                                FontSize="12"
                                Text="{Binding VideoDetail.Year}"
                                TextColor="{StaticResource OnTertiaryContainer}" />
                        </Border>

                        <Border
                            Padding="6,2"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariant},
                                                              Dark={StaticResource Gray900}}"
                            StrokeShape="RoundRectangle 4">
                            <Label
                                FontSize="12"
                                Text="{Binding VideoDetail.SourceName}"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                            Dark={StaticResource Gray300}}" />
                        </Border>
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <HorizontalStackLayout Spacing="4">
                            <Label
                                FontAttributes="Bold"
                                FontSize="15"
                                Text="导演:"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                            Dark={StaticResource Gray400}}" />
                            <Label
                                FontSize="13"
                                LineBreakMode="TailTruncation"
                                Text="{Binding VideoDetail.Director}"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                            Dark={StaticResource Gray200}}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="4">
                            <Label
                                FontAttributes="Bold"
                                FontSize="15"
                                Text="演员:"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                            Dark={StaticResource Gray400}}" />
                            <Label
                                FontSize="13"
                                LineBreakMode="TailTruncation"
                                MaxLines="1"
                                Text="{Binding VideoDetail.Actor}"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                            Dark={StaticResource Gray200}}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <uranium:ExpanderView>
                        <uranium:ExpanderView.Header>
                            <Label Text="剧情" />
                        </uranium:ExpanderView.Header>
                        <Label
                            FontSize="13"
                            LineBreakMode="WordWrap"
                            Text="{Binding VideoDetail.Desc}"
                            TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                        Dark={StaticResource Gray400}}" />
                    </uranium:ExpanderView>


                </VerticalStackLayout>
            </ScrollView>

            <Grid Grid.Row="1" RowDefinitions="Auto,*">
                <Label
                    Grid.Row="0"
                    Margin="0,0,0,6"
                    FontAttributes="Bold"
                    FontSize="15"
                    Text="剧集"
                    TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                Dark={StaticResource White}}" />

                <ScrollView Grid.Row="1">

                    <CollectionView
                        ItemSizingStrategy="MeasureFirstItem"
                        ItemsLayout="{OnIdiom Phone=VerticalGrid\, 3,
                                              Tablet=VerticalGrid\, 5,
                                              Desktop=VerticalGrid\, 6,
                                              TV=VerticalGrid\, 6}"
                        ItemsSource="{Binding Episodes}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:EpisodeSubjectItem">
                                <Border
                                    Margin="4,3"
                                    Padding="8,6"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                                      Dark={StaticResource Gray900}}"
                                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                                             Dark={StaticResource Gray600}}"
                                    StrokeShape="RoundRectangle 8">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PlayerViewModel}}, Path=SelectEpisodeCommand}" CommandParameter="{Binding}" />
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="2">
                                        <ImageButton
                                            BackgroundColor="Transparent"
                                            HeightRequest="24"
                                            HorizontalOptions="Center"
                                            Source="{FontImageSource FontFamily=MaterialOutlined,
                                                                     Glyph={x:Static materialSyml:MaterialOutlined.Play_circle},
                                                                     Size=18,
                                                                     Color={StaticResource Primary}}"
                                            WidthRequest="24" />
                                        <Label
                                            FontSize="12"
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            LineBreakMode="TailTruncation"
                                            Text="{Binding Name}"
                                            TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                                        Dark={StaticResource White}}"
                                            VerticalOptions="Center"
                                            VerticalTextAlignment="Center" />
                                        <Label
                                            FontSize="12"
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            IsVisible="{Binding Watched}"
                                            LineBreakMode="TailTruncation"
                                            Text="✔"
                                            TextColor="Orange"
                                            VerticalOptions="Center"
                                            VerticalTextAlignment="Center" />
                                    </HorizontalStackLayout>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroupList>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal" />
                                                <VisualState x:Name="PointerOver">
                                                    <VisualState.Setters>
                                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource Gray900}}" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateGroupList>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </ScrollView>
            </Grid>

        </Grid>

    </Grid>

</ContentPage>
<?xml version="1.0" encoding="UTF-8" ?>

<uranium:UraniumContentPage
    x:Class="Lunadroid.App.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:materialSymbols="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:models="clr-namespace:Lunadroid.Core.Models;assembly=Lunadroid.Core"
    xmlns:uranium="clr-namespace:UraniumUI.Pages;assembly=UraniumUI"
    xmlns:vm="clr-namespace:Lunadroid.App.ViewModels"
    Title="播放历史"
    x:DataType="vm:HistoryViewModel">

    <Grid RowDefinitions="*">
        <Border StyleClass="SurfaceContainer,Rounded,Elevation1">
            <material:TabView TabHeaderItemColumnWidth="*">

                <material:TabItem Title="在线历史">
                    <material:TabItem.ContentTemplate>
                        <DataTemplate>
                            <Grid RowDefinitions="*">
                                <CollectionView
                                    Grid.Row="0"
                                    Margin="8,4"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=HasOnlineHistories}"
                                    ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=OnlineHistories}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:PlayHistory">
                                            <Border
                                                Margin="4,3"
                                                Padding="12,10"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                                                  Dark={StaticResource Gray900}}"
                                                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                                                         Dark={StaticResource Gray600}}"
                                                StrokeShape="RoundRectangle 10">
                                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                                    <Label
                                                        Grid.Row="0"
                                                        Grid.Column="0"
                                                        FontAttributes="Bold"
                                                        FontSize="15"
                                                        LineBreakMode="TailTruncation"
                                                        Text="{Binding Name}"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                                                    Dark={StaticResource White}}" />
                                                    <Label
                                                        Grid.Row="1"
                                                        Grid.Column="0"
                                                        FontSize="12"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                                                    Dark={StaticResource Gray400}}">
                                                        <Label.Text>
                                                            <MultiBinding StringFormat="{}{0} · {1}">
                                                                <Binding Path="Source" />
                                                                <Binding Path="Episode" />
                                                            </MultiBinding>
                                                        </Label.Text>
                                                    </Label>
                                                    <Label
                                                        Grid.Row="2"
                                                        Grid.Column="0"
                                                        FontSize="11"
                                                        Text="{Binding UpdateTime, Converter={StaticResource RelativeTimeConverter}}"
                                                        TextColor="{AppThemeBinding Light={StaticResource Outline},
                                                                                    Dark={StaticResource Gray500}}" />
                                                    <ImageButton
                                                        Grid.Row="0"
                                                        Grid.RowSpan="3"
                                                        Grid.Column="1"
                                                        BackgroundColor="Transparent"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=DeleteHistoryCommand}"
                                                        CommandParameter="{Binding}"
                                                        HeightRequest="32"
                                                        HorizontalOptions="Center"
                                                        Source="{FontImageSource FontFamily=MaterialOutlined,
                                                                                 Size=20,
                                                                                 Color={AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                                                                        Dark={StaticResource Gray400}},
                                                                                 Glyph={x:Static materialSymbols:MaterialOutlined.Delete}}"
                                                        VerticalOptions="Center"
                                                        WidthRequest="32" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <VerticalStackLayout
                                    Grid.Row="0"
                                    Margin="0,60,0,0"
                                    HorizontalOptions="Center"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=HasOnlineHistories, Converter={StaticResource InvertedBoolConverter}}"
                                    Spacing="12"
                                    VerticalOptions="Center">
                                    <Label
                                        FontSize="48"
                                        HorizontalOptions="Center"
                                        Text="🌐" />
                                    <Label
                                        FontSize="16"
                                        HorizontalOptions="Center"
                                        Text="暂无在线播放历史"
                                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                                    Dark={StaticResource Gray400}}" />
                                    <Label
                                        FontSize="13"
                                        HorizontalOptions="Center"
                                        Text="搜索并播放在线影视后将自动记录"
                                        TextColor="{AppThemeBinding Light={StaticResource Outline},
                                                                    Dark={StaticResource Gray500}}" />
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </material:TabItem.ContentTemplate>
                </material:TabItem>

                <material:TabItem Title="本地历史">
                    <material:TabItem.ContentTemplate>
                        <DataTemplate>
                            <Grid RowDefinitions="*">
                                <CollectionView
                                    Grid.Row="0"
                                    Margin="8,4"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=HasLocalHistories}"
                                    ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=LocalHistories}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:PlayHistory">
                                            <Border
                                                Margin="4,3"
                                                Padding="12,10"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                                                  Dark={StaticResource Gray900}}"
                                                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant},
                                                                         Dark={StaticResource Gray600}}"
                                                StrokeShape="RoundRectangle 10">
                                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                                    <Label
                                                        Grid.Row="0"
                                                        Grid.Column="0"
                                                        FontAttributes="Bold"
                                                        FontSize="15"
                                                        LineBreakMode="TailTruncation"
                                                        Text="{Binding Name}"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnSurface},
                                                                                    Dark={StaticResource White}}" />
                                                    <Label
                                                        Grid.Row="1"
                                                        Grid.Column="0"
                                                        FontSize="12"
                                                        LineBreakMode="TailTruncation"
                                                        Text="{Binding Url}"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                                                    Dark={StaticResource Gray400}}" />
                                                    <Label
                                                        Grid.Row="2"
                                                        Grid.Column="0"
                                                        FontSize="11"
                                                        Text="{Binding UpdateTime, Converter={StaticResource RelativeTimeConverter}}"
                                                        TextColor="{AppThemeBinding Light={StaticResource Outline},
                                                                                    Dark={StaticResource Gray500}}" />
                                                    <ImageButton
                                                        Grid.Row="0"
                                                        Grid.RowSpan="3"
                                                        Grid.Column="1"
                                                        BackgroundColor="Transparent"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=DeleteHistoryCommand}"
                                                        CommandParameter="{Binding}"
                                                        HeightRequest="32"
                                                        HorizontalOptions="Center"
                                                        Source="{FontImageSource FontFamily=MaterialOutlined,
                                                                                 Size=20,
                                                                                 Color={AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                                                                        Dark={StaticResource Gray400}},
                                                                                 Glyph={x:Static materialSymbols:MaterialOutlined.Delete}}"
                                                        VerticalOptions="Center"
                                                        WidthRequest="32" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <VerticalStackLayout
                                    Grid.Row="0"
                                    Margin="0,60,0,0"
                                    HorizontalOptions="Center"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=HasLocalHistories, Converter={StaticResource InvertedBoolConverter}}"
                                    Spacing="12"
                                    VerticalOptions="Center">
                                    <Label
                                        FontSize="48"
                                        HorizontalOptions="Center"
                                        Text="📁" />
                                    <Label
                                        FontSize="16"
                                        HorizontalOptions="Center"
                                        Text="暂无本地播放历史"
                                        TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                                    Dark={StaticResource Gray400}}" />
                                    <Label
                                        FontSize="13"
                                        HorizontalOptions="Center"
                                        Text="播放本地视频后将自动记录"
                                        TextColor="{AppThemeBinding Light={StaticResource Outline},
                                                                    Dark={StaticResource Gray500}}" />
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </material:TabItem.ContentTemplate>
                </material:TabItem>

            </material:TabView>
        </Border>
    </Grid>

</uranium:UraniumContentPage>
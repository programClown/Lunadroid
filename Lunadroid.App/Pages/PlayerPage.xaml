<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="Lunadroid.App.Pages.PlayerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Lunadroid.App.ViewModels"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="播放"
    Shell.NavBarIsVisible="False"
    x:DataType="viewmodels:PlayerViewModel"
    BackgroundColor="Black">

    <Grid RowDefinitions="Auto,*">

        <!-- Title Bar -->
        <Frame
            Grid.Row="0"
            BackgroundColor="#1A1A2E"
            CornerRadius="0"
            Padding="16,12"
            HasShadow="False">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Back Button -->
                <Label
                    Grid.Column="0"
                    Text="←"
                    FontSize="22"
                    TextColor="White"
                    VerticalOptions="Center"
                    Padding="0,0,12,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <!-- Title Info -->
                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="2"
                    VerticalOptions="Center">
                    <Label
                        Text="{Binding MovieTitle}"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="White"
                        MaxLines="1"
                        LineBreakMode="TailTruncation" />
                    <Label
                        Text="{Binding EpisodeName}"
                        FontSize="12"
                        TextColor="#AAAAAA"
                        MaxLines="1"
                        LineBreakMode="TailTruncation" />
                </VerticalStackLayout>
            </Grid>
        </Frame>

        <!-- Video Player -->
        <toolkit:MediaElement
            Grid.Row="1"
            Source="{Binding VideoUrl}"
            ShouldAutoPlay="True"
            ShouldShowPlaybackControls="True"
            Aspect="AspectFit"
            BackgroundColor="Black" />

    </Grid>

</ContentPage>

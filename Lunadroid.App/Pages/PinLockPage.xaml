<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="Lunadroid.App.Pages.PinLockPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Lunadroid.App.ViewModels"
    Shell.NavBarIsVisible="False"
    x:DataType="viewmodels:PinLockViewModel"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A2E}">

    <Grid RowDefinitions="*,Auto,*" Padding="32">

        <!-- Title -->
        <VerticalStackLayout
            Grid.Row="0"
            VerticalOptions="End"
            Spacing="16"
            Padding="0,0,0,32">
            <Label
                FontSize="24"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                HorizontalOptions="Center">
                <Label.Triggers>
                    <DataTrigger
                        TargetType="Label"
                        Binding="{Binding IsSetupMode}"
                        Value="True">
                        <Setter Property="Text" Value="设置PIN" />
                    </DataTrigger>
                    <DataTrigger
                        TargetType="Label"
                        Binding="{Binding IsConfirmPhase}"
                        Value="True">
                        <Setter Property="Text" Value="确认PIN" />
                    </DataTrigger>
                    <DataTrigger
                        TargetType="Label"
                        Binding="{Binding IsSetupMode}"
                        Value="False">
                        <Setter Property="Text" Value="输入PIN" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>

            <Label
                Text="{Binding Subtitle}"
                FontSize="14"
                TextColor="{AppThemeBinding Light=#777777, Dark=#999999}"
                HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- PIN Display -->
        <HorizontalStackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            Spacing="16"
            Padding="0,24">

            <!-- Dot 1 -->
            <Ellipse
                WidthRequest="16"
                HeightRequest="16"
                Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                StrokeThickness="2">
                <Ellipse.Triggers>
                    <DataTrigger
                        TargetType="Ellipse"
                        Binding="{Binding PinLength}"
                        Value="1">
                        <Setter Property="Fill" Value="#6C63FF" />
                        <Setter Property="Stroke" Value="#6C63FF" />
                    </DataTrigger>
                    <DataTrigger
                        TargetType="Ellipse"
                        Binding="{Binding PinLength}"
                        Value="2">
                        <Setter Property="Fill" Value="#6C63FF" />
                        <Setter Property="Stroke" Value="#6C63FF" />
                    </DataTrigger>
                    <DataTrigger
                        TargetType="Ellipse"
                        Binding="{Binding PinLength}"
                        Value="3">
                        <Setter Property="Fill" Value="#6C63FF" />
                        <Setter Property="Stroke" Value="#6C63FF" />
                    </DataTrigger>
                    <DataTrigger
                        TargetType="Ellipse"
                        Binding="{Binding PinLength}"
                        Value="4">
                        <Setter Property="Fill" Value="#6C63FF" />
                        <Setter Property="Stroke" Value="#6C63FF" />
                    </DataTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- Dot 2 -->
            <Ellipse
                WidthRequest="16"
                HeightRequest="16"
                Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                StrokeThickness="2">
                <Ellipse.Triggers>
                    <DataTrigger
                        TargetType="Ellipse"
                        Binding="{Binding PinLength}"
                        Value="2">
                        <Setter Property="Fill" Value="#6C63FF" />
                        <Setter Property="Stroke" Value="#6C63FF" />
                    </DataTrigger>
                    <DataTrigger
                        TargetType="Ellipse"
                        Binding="{Binding PinLength}"
                        Value="3">
                        <Setter Property="Fill" Value="#6C63FF" />
                        <Setter Property="Stroke" Value="#6C63FF" />
                    </DataTrigger>
                    <DataTrigger
                        TargetType="Ellipse"
                        Binding="{Binding PinLength}"
                        Value="4">
                        <Setter Property="Fill" Value="#6C63FF" />
                        <Setter Property="Stroke" Value="#6C63FF" />
                    </DataTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- Dot 3 -->
            <Ellipse
                WidthRequest="16"
                HeightRequest="16"
                Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                StrokeThickness="2">
                <Ellipse.Triggers>
                    <DataTrigger
                        TargetType="Ellipse"
                        Binding="{Binding PinLength}"
                        Value="3">
                        <Setter Property="Fill" Value="#6C63FF" />
                        <Setter Property="Stroke" Value="#6C63FF" />
                    </DataTrigger>
                    <DataTrigger
                        TargetType="Ellipse"
                        Binding="{Binding PinLength}"
                        Value="4">
                        <Setter Property="Fill" Value="#6C63FF" />
                        <Setter Property="Stroke" Value="#6C63FF" />
                    </DataTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- Dot 4 -->
            <Ellipse
                WidthRequest="16"
                HeightRequest="16"
                Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                StrokeThickness="2">
                <Ellipse.Triggers>
                    <DataTrigger
                        TargetType="Ellipse"
                        Binding="{Binding PinLength}"
                        Value="4">
                        <Setter Property="Fill" Value="#6C63FF" />
                        <Setter Property="Stroke" Value="#6C63FF" />
                    </DataTrigger>
                </Ellipse.Triggers>
            </Ellipse>

        </HorizontalStackLayout>

        <!-- Number Pad + Error -->
        <VerticalStackLayout
            Grid.Row="2"
            Spacing="16"
            VerticalOptions="Start">

            <!-- Error Message -->
            <Label
                Text="{Binding ErrorMessage}"
                FontSize="13"
                TextColor="#FF4444"
                HorizontalOptions="Center"
                IsVisible="{Binding HasError}" />

            <!-- Number Pad Grid -->
            <Grid
                RowDefinitions="64,64,64,64"
                ColumnDefinitions="*,*,*"
                RowSpacing="12"
                ColumnSpacing="12"
                MaximumWidthRequest="300"
                HorizontalOptions="Center">

                <!-- Row 1: 1 2 3 -->
                <Button
                    Grid.Row="0" Grid.Column="0"
                    Text="1"
                    FontSize="24"
                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#333344}"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding EnterDigitCommand}"
                    CommandParameter="1" />
                <Button
                    Grid.Row="0" Grid.Column="1"
                    Text="2"
                    FontSize="24"
                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#333344}"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding EnterDigitCommand}"
                    CommandParameter="2" />
                <Button
                    Grid.Row="0" Grid.Column="2"
                    Text="3"
                    FontSize="24"
                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#333344}"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding EnterDigitCommand}"
                    CommandParameter="3" />

                <!-- Row 2: 4 5 6 -->
                <Button
                    Grid.Row="1" Grid.Column="0"
                    Text="4"
                    FontSize="24"
                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#333344}"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding EnterDigitCommand}"
                    CommandParameter="4" />
                <Button
                    Grid.Row="1" Grid.Column="1"
                    Text="5"
                    FontSize="24"
                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#333344}"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding EnterDigitCommand}"
                    CommandParameter="5" />
                <Button
                    Grid.Row="1" Grid.Column="2"
                    Text="6"
                    FontSize="24"
                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#333344}"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding EnterDigitCommand}"
                    CommandParameter="6" />

                <!-- Row 3: 7 8 9 -->
                <Button
                    Grid.Row="2" Grid.Column="0"
                    Text="7"
                    FontSize="24"
                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#333344}"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding EnterDigitCommand}"
                    CommandParameter="7" />
                <Button
                    Grid.Row="2" Grid.Column="1"
                    Text="8"
                    FontSize="24"
                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#333344}"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding EnterDigitCommand}"
                    CommandParameter="8" />
                <Button
                    Grid.Row="2" Grid.Column="2"
                    Text="9"
                    FontSize="24"
                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#333344}"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding EnterDigitCommand}"
                    CommandParameter="9" />

                <!-- Row 4: Delete 0 Confirm -->
                <Button
                    Grid.Row="3" Grid.Column="0"
                    Text="⌫"
                    FontSize="22"
                    TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                    BackgroundColor="Transparent"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding DeleteDigitCommand}" />
                <Button
                    Grid.Row="3" Grid.Column="1"
                    Text="0"
                    FontSize="24"
                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                    BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#333344}"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding EnterDigitCommand}"
                    CommandParameter="0" />
                <Button
                    Grid.Row="3" Grid.Column="2"
                    Text="✓"
                    FontSize="22"
                    TextColor="White"
                    BackgroundColor="#6C63FF"
                    CornerRadius="32"
                    HeightRequest="64"
                    Command="{Binding ConfirmCommand}" />

            </Grid>
        </VerticalStackLayout>

    </Grid>

</ContentPage>

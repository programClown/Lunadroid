<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="Lunadroid.App.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Lunadroid.App.ViewModels"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    Title="搜索"
    x:DataType="viewmodels:HomeViewModel"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A2E}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Search Bar -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="*,Auto"
            Padding="16,12"
            ColumnSpacing="8">
            <material:TextField
                Grid.Column="0"
                Text="{Binding SearchText}"
                ReturnType="Search"
                Completed="OnSearchCompleted"
                AllowClear="True"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A3E}"
                TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}" />
            <Button
                Grid.Column="1"
                Text="搜索"
                FontSize="14"
                FontAttributes="Bold"
                TextColor="White"
                BackgroundColor="#6C63FF"
                CornerRadius="20"
                WidthRequest="80"
                HeightRequest="42"
                Command="{Binding SearchCommand}" />
        </Grid>

        <!-- Search History Chips -->
        <ScrollView
            Grid.Row="1"
            Orientation="Horizontal"
            HorizontalScrollBarVisibility="Never"
            Padding="16,0"
            IsVisible="{Binding HasSearchHistories}">
            <HorizontalStackLayout Spacing="8"
                BindableLayout.ItemsSource="{Binding SearchHistories}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border
                            StrokeShape="RoundRectangle 16"
                            Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#444444}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A3E}"
                            Padding="12,6"
                            HeightRequest="34">
                            <HorizontalStackLayout Spacing="6">
                                <Label
                                    Text="{Binding Keyword}"
                                    FontSize="12"
                                    TextColor="{AppThemeBinding Light=#555555, Dark=#CCCCCC}"
                                    VerticalOptions="Center" />
                                <Label
                                    Text="✕"
                                    FontSize="10"
                                    TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    WidthRequest="16"
                                    HeightRequest="16">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomeViewModel}}, Path=DeleteHistoryCommand}"
                                            CommandParameter="{Binding Id}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomeViewModel}}, Path=SelectHistoryCommand}"
                                    CommandParameter="{Binding Keyword}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Search Results -->
        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding SearchResults}"
            Margin="16,8"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame
                        Padding="12"
                        Margin="0,4"
                        CornerRadius="12"
                        HasShadow="False"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A3E}">
                        <Grid ColumnDefinitions="80,*" ColumnSpacing="12">
                            <!-- Poster -->
                            <Frame
                                Grid.Column="0"
                                WidthRequest="80"
                                HeightRequest="110"
                                CornerRadius="8"
                                IsClippedToBounds="True"
                                Padding="0"
                                HasShadow="False">
                                <Image
                                    Source="{Binding PosterUrl}"
                                    Aspect="AspectFill"
                                    WidthRequest="80"
                                    HeightRequest="110" />
                            </Frame>

                            <!-- Info -->
                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="6"
                                VerticalOptions="Center">
                                <Label
                                    Text="{Binding Title}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                                    MaxLines="2"
                                    LineBreakMode="TailTruncation" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label
                                        Text="★"
                                        FontSize="14"
                                        TextColor="#FFB800"
                                        VerticalOptions="Center" />
                                    <Label
                                        Text="{Binding Rating}"
                                        FontSize="14"
                                        TextColor="#FFB800"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="8">
                                    <Label
                                        Text="{Binding SourceName}"
                                        FontSize="12"
                                        TextColor="#6C63FF"
                                        VerticalOptions="Center" />
                                    <Label
                                        Text="{Binding Year}"
                                        FontSize="12"
                                        TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomeViewModel}}, Path=SelectMovieCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <!-- Empty State -->
            <CollectionView.EmptyView>
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="8"
                    Padding="40">
                    <Label
                        Text="🔍"
                        FontSize="48"
                        HorizontalOptions="Center" />
                    <Label
                        Text="输入影片名称开始搜索"
                        FontSize="14"
                        TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Loading Overlay -->
        <Grid
            Grid.Row="2"
            IsVisible="{Binding IsSearching}"
            BackgroundColor="#80000000"
            InputTransparent="False">
            <VerticalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="16">
                <ActivityIndicator
                    IsRunning="{Binding IsSearching}"
                    Color="#6C63FF"
                    WidthRequest="48"
                    HeightRequest="48"
                    HorizontalOptions="Center" />
                <Label
                    Text="搜索中...请耐心等待"
                    FontSize="14"
                    TextColor="White"
                    HorizontalOptions="Center" />
                <Button
                    Text="取消"
                    FontSize="13"
                    TextColor="White"
                    BackgroundColor="#FF4444"
                    CornerRadius="16"
                    WidthRequest="80"
                    HeightRequest="36"
                    HorizontalOptions="Center"
                    Command="{Binding CancelSearchCommand}" />
            </VerticalStackLayout>
        </Grid>

    </Grid>

</ContentPage>

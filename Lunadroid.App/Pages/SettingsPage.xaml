<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="Lunadroid.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Lunadroid.App.ViewModels"
    Title="设置"
    x:DataType="viewmodels:SettingsViewModel"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A2E}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">

            <!-- Theme Section -->
            <Frame
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A3E}"
                CornerRadius="12"
                HasShadow="False"
                Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="主题"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}" />

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Button
                            Grid.Column="0"
                            Text="浅色"
                            FontSize="13"
                            CornerRadius="20"
                            HeightRequest="40"
                            Command="{Binding ChangeThemeCommand}"
                            CommandParameter="Light" />
                        <Button
                            Grid.Column="1"
                            Text="深色"
                            FontSize="13"
                            CornerRadius="20"
                            HeightRequest="40"
                            Command="{Binding ChangeThemeCommand}"
                            CommandParameter="Dark" />
                        <Button
                            Grid.Column="2"
                            Text="跟随系统"
                            FontSize="13"
                            CornerRadius="20"
                            HeightRequest="40"
                            Command="{Binding ChangeThemeCommand}"
                            CommandParameter="System" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Security Section -->
            <Frame
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A3E}"
                CornerRadius="12"
                HasShadow="False"
                Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="安全"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}" />

                    <!-- Security Lock Toggle -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label
                                Text="应用锁"
                                FontSize="15"
                                TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}" />
                            <Label
                                Text="启用PIN码保护应用启动"
                                FontSize="12"
                                TextColor="{AppThemeBinding Light=#999999, Dark=#777777}" />
                        </VerticalStackLayout>
                        <Switch
                            Grid.Column="1"
                            IsToggled="{Binding SecurityLockEnabled}"
                            OnColor="#6C63FF"
                            ThumbColor="White"
                            VerticalOptions="Center" />
                    </Grid>

                    <!-- Set PIN Button -->
                    <Button
                        Text="设置PIN"
                        FontSize="13"
                        TextColor="#6C63FF"
                        BackgroundColor="Transparent"
                        BorderColor="#6C63FF"
                        BorderWidth="1"
                        CornerRadius="20"
                        HeightRequest="40"
                        HorizontalOptions="Start"
                        Command="{Binding SetupPinCommand}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Data Section -->
            <Frame
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A3E}"
                CornerRadius="12"
                HasShadow="False"
                Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="数据管理"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}" />

                    <Button
                        Text="清除所有数据"
                        FontSize="14"
                        TextColor="White"
                        BackgroundColor="#FF4444"
                        CornerRadius="20"
                        HeightRequest="44"
                        Command="{Binding ClearAllDataCommand}" />

                    <Button
                        Text="重置应用"
                        FontSize="14"
                        TextColor="White"
                        BackgroundColor="#FF4444"
                        CornerRadius="20"
                        HeightRequest="44"
                        Command="{Binding ResetAppCommand}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Version Info -->
            <VerticalStackLayout
                Spacing="4"
                Padding="0,20,0,16">
                <Label
                    Text="{Binding AppVersion}"
                    FontSize="13"
                    TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                    HorizontalOptions="Center" />
                <Label
                    Text="Lunadroid"
                    FontSize="11"
                    TextColor="{AppThemeBinding Light=#BBBBBB, Dark=#555555}"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

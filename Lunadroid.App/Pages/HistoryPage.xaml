<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="Lunadroid.App.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Lunadroid.App.ViewModels"
    xmlns:converters="clr-namespace:Lunadroid.App.Converters"
    Title="历史记录"
    x:DataType="viewmodels:HistoryViewModel"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A2E}">

    <ContentPage.Resources>
        <converters:RelativeTimeConverter x:Key="RelativeTimeConverter" />
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:BoolInverterConverter x:Key="BoolInverterConverter" />
        <converters:PlayProgressConverter x:Key="PlayProgressConverter" />
        <converters:DownloadProgressConverter x:Key="DownloadProgressConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Text="清除全部"
            Clicked="OnClearAllClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*">

        <!-- Tab Buttons -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="*,*"
            Padding="16,12"
            ColumnSpacing="12">

            <Button
                Grid.Column="0"
                Text="播放记录"
                FontSize="14"
                FontAttributes="Bold"
                CornerRadius="20"
                HeightRequest="40"
                Command="{Binding SwitchTabCommand}"
                CommandParameter="Play">
                <Button.Triggers>
                    <DataTrigger
                        TargetType="Button"
                        Binding="{Binding ActiveTab}"
                        Value="Play">
                        <Setter Property="BackgroundColor" Value="#6C63FF" />
                        <Setter Property="TextColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger
                        TargetType="Button"
                        Binding="{Binding ActiveTab}"
                        Value="Download">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" />
                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#777777, Dark=#AAAAAA}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <Button
                Grid.Column="1"
                Text="下载记录"
                FontSize="14"
                FontAttributes="Bold"
                CornerRadius="20"
                HeightRequest="40"
                Command="{Binding SwitchTabCommand}"
                CommandParameter="Download">
                <Button.Triggers>
                    <DataTrigger
                        TargetType="Button"
                        Binding="{Binding ActiveTab}"
                        Value="Download">
                        <Setter Property="BackgroundColor" Value="#6C63FF" />
                        <Setter Property="TextColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger
                        TargetType="Button"
                        Binding="{Binding ActiveTab}"
                        Value="Play">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" />
                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#777777, Dark=#AAAAAA}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

        </Grid>

        <!-- Play History Tab -->
        <Grid
            Grid.Row="1"
            IsVisible="{Binding IsPlayTabActive}"
            RowDefinitions="Auto,*">

            <!-- Time Filter Buttons -->
            <HorizontalStackLayout
                Grid.Row="0"
                Spacing="8"
                Padding="16,0,16,8">
                <Button
                    Text="日"
                    FontSize="12"
                    CornerRadius="14"
                    HeightRequest="30"
                    WidthRequest="50"
                    Padding="4,2"
                    Command="{Binding FilterPlayTimeCommand}"
                    CommandParameter="Day" />
                <Button
                    Text="月"
                    FontSize="12"
                    CornerRadius="14"
                    HeightRequest="30"
                    WidthRequest="50"
                    Padding="4,2"
                    Command="{Binding FilterPlayTimeCommand}"
                    CommandParameter="Month" />
                <Button
                    Text="年"
                    FontSize="12"
                    CornerRadius="14"
                    HeightRequest="30"
                    WidthRequest="50"
                    Padding="4,2"
                    Command="{Binding FilterPlayTimeCommand}"
                    CommandParameter="Year" />
                <Button
                    Text="全部"
                    FontSize="12"
                    CornerRadius="14"
                    HeightRequest="30"
                    WidthRequest="56"
                    Padding="4,2"
                    Command="{Binding FilterPlayTimeCommand}"
                    CommandParameter="All" />
            </HorizontalStackLayout>

            <!-- Play History List -->
            <CollectionView
                Grid.Row="1"
                ItemsSource="{Binding PlayHistoryItems}"
                Margin="16,0"
                SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame
                            Padding="12"
                            Margin="0,4"
                            CornerRadius="12"
                            HasShadow="False"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A3E}">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout
                                    Grid.Column="0"
                                    Spacing="4">
                                    <Label
                                        Text="{Binding MovieTitle}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                                        MaxLines="1"
                                        LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label
                                            Text="{Binding SourceName}"
                                            FontSize="12"
                                            TextColor="#6C63FF" />
                                        <Label
                                            Text="{Binding EpisodeName}"
                                            FontSize="12"
                                            TextColor="{AppThemeBinding Light=#777777, Dark=#999999}" />
                                    </HorizontalStackLayout>

                                    <!-- Progress Bar -->
                                    <ProgressBar
                                        Progress="{Binding PlayProgress}"
                                        ProgressColor="#6C63FF"
                                        HeightRequest="4"
                                        Margin="0,4,0,2" />

                                    <Label
                                        Text="{Binding LastWatchedAt, Converter={StaticResource RelativeTimeConverter}}"
                                        FontSize="11"
                                        TextColor="{AppThemeBinding Light=#999999, Dark=#777777}" />
                                </VerticalStackLayout>

                                <!-- Delete Button -->
                                <Label
                                    Grid.Column="1"
                                    Text="🗑"
                                    FontSize="18"
                                    TextColor="#FF4444"
                                    VerticalOptions="Center"
                                    Padding="8,0,0,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HistoryViewModel}}, Path=DeletePlayHistoryCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="8">
                        <Label
                            Text="暂无播放记录"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                            HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

        <!-- Download History Tab -->
        <Grid
            Grid.Row="1"
            IsVisible="{Binding IsDownloadTabActive}"
            RowDefinitions="Auto,Auto,*">

            <!-- Search Entry -->
            <Entry
                Grid.Row="0"
                Text="{Binding DownloadSearchText}"
                Placeholder="搜索下载记录..."
                Margin="16,0"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A3E}"
                TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}" />

            <!-- Filter Buttons -->
            <HorizontalStackLayout
                Grid.Row="1"
                Spacing="8"
                Padding="16,8">
                <Button
                    Text="全部"
                    FontSize="12"
                    CornerRadius="14"
                    HeightRequest="30"
                    WidthRequest="56"
                    Padding="4,2"
                    Command="{Binding FilterDownloadStatusCommand}"
                    CommandParameter="All" />
                <Button
                    Text="已完成"
                    FontSize="12"
                    CornerRadius="14"
                    HeightRequest="30"
                    WidthRequest="64"
                    Padding="4,2"
                    Command="{Binding FilterDownloadStatusCommand}"
                    CommandParameter="Completed" />
                <Button
                    Text="下载中"
                    FontSize="12"
                    CornerRadius="14"
                    HeightRequest="30"
                    WidthRequest="64"
                    Padding="4,2"
                    Command="{Binding FilterDownloadStatusCommand}"
                    CommandParameter="Downloading" />
                <Button
                    Text="失败"
                    FontSize="12"
                    CornerRadius="14"
                    HeightRequest="30"
                    WidthRequest="56"
                    Padding="4,2"
                    Command="{Binding FilterDownloadStatusCommand}"
                    CommandParameter="Failed" />
            </HorizontalStackLayout>

            <!-- Download History List -->
            <CollectionView
                Grid.Row="2"
                ItemsSource="{Binding DownloadHistoryItems}"
                Margin="16,0"
                SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame
                            Padding="12"
                            Margin="0,4"
                            CornerRadius="12"
                            HasShadow="False"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A3E}">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout
                                    Grid.Column="0"
                                    Spacing="4">
                                    <Label
                                        Text="{Binding MovieTitle}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                                        MaxLines="1"
                                        LineBreakMode="TailTruncation" />

                                    <Label
                                        Text="{Binding EpisodeName}"
                                        FontSize="12"
                                        TextColor="{AppThemeBinding Light=#777777, Dark=#999999}" />

                                    <!-- Status Badge -->
                                    <Border
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        Padding="8,2"
                                        HorizontalOptions="Start">
                                        <Border.Triggers>
                                            <DataTrigger
                                                TargetType="Border"
                                                Binding="{Binding Status}"
                                                Value="Completed">
                                                <Setter Property="BackgroundColor" Value="#E8F5E9" />
                                            </DataTrigger>
                                            <DataTrigger
                                                TargetType="Border"
                                                Binding="{Binding Status}"
                                                Value="Downloading">
                                                <Setter Property="BackgroundColor" Value="#E3F2FD" />
                                            </DataTrigger>
                                            <DataTrigger
                                                TargetType="Border"
                                                Binding="{Binding Status}"
                                                Value="Failed">
                                                <Setter Property="BackgroundColor" Value="#FFEBEE" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label
                                            Text="{Binding StatusText}"
                                            FontSize="11"
                                            FontAttributes="Bold">
                                            <Label.Triggers>
                                                <DataTrigger
                                                    TargetType="Label"
                                                    Binding="{Binding Status}"
                                                    Value="Completed">
                                                    <Setter Property="TextColor" Value="#2E7D32" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    TargetType="Label"
                                                    Binding="{Binding Status}"
                                                    Value="Downloading">
                                                    <Setter Property="TextColor" Value="#1565C0" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    TargetType="Label"
                                                    Binding="{Binding Status}"
                                                    Value="Failed">
                                                    <Setter Property="TextColor" Value="#C62828" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>

                                    <!-- Download Progress -->
                                    <ProgressBar
                                        Progress="{Binding DownloadProgress}"
                                        HeightRequest="4"
                                        Margin="0,2">
                                        <ProgressBar.Triggers>
                                            <DataTrigger
                                                TargetType="ProgressBar"
                                                Binding="{Binding Status}"
                                                Value="Completed">
                                                <Setter Property="ProgressColor" Value="#4CAF50" />
                                            </DataTrigger>
                                            <DataTrigger
                                                TargetType="ProgressBar"
                                                Binding="{Binding Status}"
                                                Value="Downloading">
                                                <Setter Property="ProgressColor" Value="#2196F3" />
                                            </DataTrigger>
                                            <DataTrigger
                                                TargetType="ProgressBar"
                                                Binding="{Binding Status}"
                                                Value="Failed">
                                                <Setter Property="ProgressColor" Value="#F44336" />
                                            </DataTrigger>
                                        </ProgressBar.Triggers>
                                    </ProgressBar>

                                    <HorizontalStackLayout Spacing="8">
                                        <Label
                                            Text="{Binding FileSizeBytes, Converter={StaticResource FileSizeConverter}}"
                                            FontSize="11"
                                            TextColor="{AppThemeBinding Light=#999999, Dark=#777777}" />
                                        <Label
                                            Text="{Binding CreatedAt, Converter={StaticResource RelativeTimeConverter}}"
                                            FontSize="11"
                                            TextColor="{AppThemeBinding Light=#999999, Dark=#777777}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Delete Button -->
                                <Label
                                    Grid.Column="1"
                                    Text="🗑"
                                    FontSize="18"
                                    TextColor="#FF4444"
                                    VerticalOptions="Center"
                                    Padding="8,0,0,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HistoryViewModel}}, Path=DeleteDownloadHistoryCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="8">
                        <Label
                            Text="暂无下载记录"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                            HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

    </Grid>

</ContentPage>

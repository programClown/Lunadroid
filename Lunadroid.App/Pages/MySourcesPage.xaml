<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="Lunadroid.App.Pages.MySourcesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Lunadroid.App.ViewModels"
    xmlns:converters="clr-namespace:Lunadroid.App.Converters"
    Title="我的源"
    x:DataType="viewmodels:MySourcesViewModel"
    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A2E}">

    <ContentPage.Resources>
        <converters:BoolInverterConverter x:Key="BoolInverterConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Text="添加源"
            Order="Primary"
            Command="{Binding AddSourceCommand}" />
        <ToolbarItem
            Text="从云端导入"
            Order="Primary"
            Command="{Binding ImportFromCloudCommand}" />
        <ToolbarItem
            Text="检查网络"
            Order="Secondary"
            Command="{Binding CheckNetworkCommand}" />
    </ContentPage.ToolbarItems>

    <Grid>
        <!-- Main Content -->
        <Grid RowDefinitions="*,Auto" IsVisible="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}">

            <!-- Source List -->
            <CollectionView
                Grid.Row="0"
                ItemsSource="{Binding Sources}"
                Margin="16,12"
                SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame
                            Padding="14"
                            Margin="0,4"
                            CornerRadius="12"
                            HasShadow="False"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A3E}">
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">

                                <!-- Row 1: Status + Name + Badge + Toggle + Delete -->
                                <Grid
                                    Grid.Row="0"
                                    ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                                    ColumnSpacing="8">

                                    <!-- Accessibility Dot -->
                                    <Ellipse
                                        Grid.Column="0"
                                        WidthRequest="10"
                                        HeightRequest="10"
                                        VerticalOptions="Center"
                                        HorizontalOptions="Center">
                                        <Ellipse.Triggers>
                                            <DataTrigger
                                                TargetType="Ellipse"
                                                Binding="{Binding IsAccessible}"
                                                Value="True">
                                                <Setter Property="Fill" Value="#4CAF50" />
                                            </DataTrigger>
                                            <DataTrigger
                                                TargetType="Ellipse"
                                                Binding="{Binding IsAccessible}"
                                                Value="False">
                                                <Setter Property="Fill" Value="#F44336" />
                                            </DataTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>

                                    <!-- Source Name -->
                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding Name}"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        TextColor="{AppThemeBinding Light=#1A1A2E, Dark=#FFFFFF}"
                                        VerticalOptions="Center"
                                        MaxLines="1"
                                        LineBreakMode="TailTruncation" />

                                    <!-- 18+ Badge -->
                                    <Border
                                        Grid.Column="2"
                                        IsVisible="{Binding IsAdult}"
                                        StrokeShape="RoundRectangle 8"
                                        Stroke="Transparent"
                                        BackgroundColor="#FF4444"
                                        Padding="6,2"
                                        VerticalOptions="Center">
                                        <Label
                                            Text="18+"
                                            FontSize="10"
                                            FontAttributes="Bold"
                                            TextColor="White" />
                                    </Border>

                                    <!-- Toggle Switch -->
                                    <Switch
                                        Grid.Column="3"
                                        IsToggled="{Binding IsEnabled}"
                                        OnColor="#6C63FF"
                                        ThumbColor="White"
                                        VerticalOptions="Center" />

                                    <!-- Delete Button -->
                                    <Label
                                        Grid.Column="4"
                                        Text="🗑"
                                        FontSize="18"
                                        TextColor="#FF4444"
                                        VerticalOptions="Center"
                                        Padding="4,0,0,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MySourcesViewModel}}, Path=DeleteSourceCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>

                                <!-- Row 2: API URL -->
                                <Label
                                    Grid.Row="1"
                                    Text="{Binding ApiUrl}"
                                    FontSize="12"
                                    TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                                    MaxLines="1"
                                    LineBreakMode="TailTruncation" />

                                <!-- Row 3: Latency Info -->
                                <HorizontalStackLayout
                                    Grid.Row="2"
                                    Spacing="8">
                                    <Label
                                        Text="{Binding AccessLatencyMs, StringFormat='{0}ms'}"
                                        FontSize="12"
                                        TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="8"
                        Padding="40">
                        <Label
                            Text="📦"
                            FontSize="48"
                            HorizontalOptions="Center" />
                        <Label
                            Text="暂无影视源，请添加或导入"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                            HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

            <!-- Bottom Action Buttons -->
            <Grid
                Grid.Row="1"
                ColumnDefinitions="*,*"
                Padding="16,8,16,16"
                ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    Text="添加源"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="White"
                    BackgroundColor="#6C63FF"
                    CornerRadius="24"
                    HeightRequest="48"
                    Command="{Binding AddSourceCommand}" />
                <Button
                    Grid.Column="1"
                    Text="从云端导入"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="White"
                    BackgroundColor="#00BFA5"
                    CornerRadius="24"
                    HeightRequest="48"
                    Command="{Binding ImportFromCloudCommand}" />
            </Grid>
        </Grid>

        <!-- Network Check Loading Overlay -->
        <Grid
            IsVisible="{Binding IsCheckingNetwork}"
            BackgroundColor="#80000000"
            InputTransparent="False">
            <VerticalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="12">
                <ActivityIndicator
                    IsRunning="{Binding IsCheckingNetwork}"
                    Color="#6C63FF"
                    WidthRequest="40"
                    HeightRequest="40"
                    HorizontalOptions="Center" />
                <Label
                    Text="正在检查网络连通性..."
                    FontSize="14"
                    TextColor="White"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Cloud Import Loading Overlay -->
        <Grid
            IsVisible="{Binding IsImportingFromCloud}"
            BackgroundColor="#80000000"
            InputTransparent="False">
            <VerticalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="12">
                <ActivityIndicator
                    IsRunning="{Binding IsImportingFromCloud}"
                    Color="#00BFA5"
                    WidthRequest="40"
                    HeightRequest="40"
                    HorizontalOptions="Center" />
                <Label
                    Text="正在从云端导入源..."
                    FontSize="14"
                    TextColor="White"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Main Loading Overlay -->
        <Grid
            IsVisible="{Binding IsLoading}"
            BackgroundColor="#80000000"
            InputTransparent="False">
            <ActivityIndicator
                IsRunning="{Binding IsLoading}"
                Color="#6C63FF"
                WidthRequest="48"
                HeightRequest="48"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        </Grid>

    </Grid>

</ContentPage>

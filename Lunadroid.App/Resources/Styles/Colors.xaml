<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#06B6D4</Color>
    <Color x:Key="OnPrimary">#FFFFFF</Color>
    <Color x:Key="PrimaryContainer">#CFFAFE</Color>
    <Color x:Key="OnPrimaryContainer">#164E63</Color>

    <Color x:Key="Secondary">#14B8A6</Color>
    <Color x:Key="OnSecondary">#FFFFFF</Color>
    <Color x:Key="SecondaryContainer">#CCFBF1</Color>
    <Color x:Key="OnSecondaryContainer">#134E4A</Color>

    <Color x:Key="Tertiary">#6366F1</Color>
    <Color x:Key="OnTertiary">#FFFFFF</Color>
    <Color x:Key="TertiaryContainer">#E0E7FF</Color>
    <Color x:Key="OnTertiaryContainer">#312E81</Color>

    <Color x:Key="Surface">#F8FAFC</Color>
    <Color x:Key="OnSurface">#0F172A</Color>
    <Color x:Key="SurfaceVariant">#E2E8F0</Color>
    <Color x:Key="OnSurfaceVariant">#475569</Color>

    <Color x:Key="Background">#F1F5F9</Color>
    <Color x:Key="OnBackground">#0F172A</Color>

    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="ErrorContainer">#FEF2F2</Color>
    <Color x:Key="OnError">#FFFFFF</Color>
    <Color x:Key="OnErrorContainer">#7F1D1D</Color>

    <Color x:Key="Outline">#94A3B8</Color>
    <Color x:Key="OutlineVariant">#CBD5E1</Color>
    <Color x:Key="Shadow">#000000</Color>

    <Color x:Key="InverseSurface">#1E293B</Color>
    <Color x:Key="InverseOnSurface">#F1F5F9</Color>

    <Color x:Key="InversePrimary">#22D3EE</Color>
    <Color x:Key="Scrim">#000000</Color>

    <!--  DARK COLORS  -->
    <Color x:Key="PrimaryDark">#22D3EE</Color>
    <Color x:Key="OnPrimaryDark">#083344</Color>
    <Color x:Key="PrimaryContainerDark">#0E7490</Color>
    <Color x:Key="OnPrimaryContainerDark">#CFFAFE</Color>

    <Color x:Key="SecondaryDark">#2DD4BF</Color>
    <Color x:Key="OnSecondaryDark">#042F2E</Color>
    <Color x:Key="SecondaryContainerDark">#0D9488</Color>
    <Color x:Key="OnSecondaryContainerDark">#CCFBF1</Color>

    <Color x:Key="TertiaryDark">#818CF8</Color>
    <Color x:Key="OnTertiaryDark">#1E1B4B</Color>
    <Color x:Key="TertiaryContainerDark">#4338CA</Color>
    <Color x:Key="OnTertiaryContainerDark">#E0E7FF</Color>

    <Color x:Key="SurfaceDark">#0F172A</Color>
    <Color x:Key="OnSurfaceDark">#E2E8F0</Color>
    <Color x:Key="SurfaceVariantDark">#1E293B</Color>
    <Color x:Key="OnSurfaceVariantDark">#94A3B8</Color>

    <Color x:Key="BackgroundDark">#0B1120</Color>
    <Color x:Key="OnBackgroundDark">#E2E8F0</Color>

    <Color x:Key="ErrorDark">#F87171</Color>
    <Color x:Key="ErrorContainerDark">#7F1D1D</Color>
    <Color x:Key="OnErrorDark">#7F1D1D</Color>
    <Color x:Key="OnErrorContainerDark">#FEF2F2</Color>

    <Color x:Key="OutlineDark">#475569</Color>
    <Color x:Key="OutlineVariantDark">#334155</Color>
    <Color x:Key="ShadowDark">#000000</Color>

    <Color x:Key="InverseSurfaceDark">#E2E8F0</Color>
    <Color x:Key="InverseOnSurfaceDark">#0F172A</Color>
    <Color x:Key="InversePrimaryDark">#06B6D4</Color>
    <Color x:Key="ScrimDark">#000000</Color>

    <Color x:Key="DisabledText">#ba919191</Color>
    <Color x:Key="DisabledBackground">#80919191</Color>


    <!--  MAUI STANDARDS  -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>
    <SolidColorBrush Color="{StaticResource Primary}" x:Key="PrimaryBrush" />
    <SolidColorBrush Color="{StaticResource Secondary}" x:Key="SecondaryBrush" />
    <SolidColorBrush Color="{StaticResource Tertiary}" x:Key="TertiaryBrush" />
    <SolidColorBrush Color="{StaticResource White}" x:Key="WhiteBrush" />
    <SolidColorBrush Color="{StaticResource Black}" x:Key="BlackBrush" />
    <SolidColorBrush Color="{StaticResource Gray100}" x:Key="Gray100Brush" />
    <SolidColorBrush Color="{StaticResource Gray200}" x:Key="Gray200Brush" />
    <SolidColorBrush Color="{StaticResource Gray300}" x:Key="Gray300Brush" />
    <SolidColorBrush Color="{StaticResource Gray400}" x:Key="Gray400Brush" />
    <SolidColorBrush Color="{StaticResource Gray500}" x:Key="Gray500Brush" />
    <SolidColorBrush Color="{StaticResource Gray600}" x:Key="Gray600Brush" />
    <SolidColorBrush Color="{StaticResource Gray900}" x:Key="Gray900Brush" />
    <SolidColorBrush Color="{StaticResource Gray950}" x:Key="Gray950Brush" />

    <Color x:Key="Yellow100Accent">#F7B548</Color>
    <Color x:Key="Yellow200Accent">#FFD590</Color>
    <Color x:Key="Yellow300Accent">#FFE5B9</Color>
    <Color x:Key="Cyan100Accent">#06B6D4</Color>
    <Color x:Key="Cyan200Accent">#22D3EE</Color>
    <Color x:Key="Cyan300Accent">#67E8F9</Color>
    <Color x:Key="Blue100Accent">#6366F1</Color>
    <Color x:Key="Blue200Accent">#818CF8</Color>
    <Color x:Key="Blue300Accent">#A5B4FC</Color>

</ResourceDictionary>
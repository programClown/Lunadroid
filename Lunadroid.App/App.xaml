<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="Lunadroid.App.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:material="clr-namespace:UraniumUI.Material.Resources;assembly=UraniumUI.Material"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" x:Name="appColors" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" x:Name="appStyles" />
                <material:StyleResource ColorsOverride="{x:Reference appColors}" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>

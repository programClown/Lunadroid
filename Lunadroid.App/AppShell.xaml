<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light={StaticResource Surface},
                                                  Dark={StaticResource SurfaceDark}}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light={StaticResource Primary},
                                                  Dark={StaticResource PrimaryDark}}"
    Shell.TabBarTitleColor="{AppThemeBinding Light={StaticResource Primary},
                                             Dark={StaticResource PrimaryDark}}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant},
                                                  Dark={StaticResource OnSurfaceVariantDark}}"
    x:Class="Lunadroid.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:local="clr-namespace:Lunadroid.App"
    xmlns:material="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    xmlns:views="clr-namespace:Lunadroid.App.Views"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Shell.Resources>
        <ResourceDictionary>
            <Style TargetType="Tab" x:Key="BaseTabStyle">
                <Setter Property="Shell.TabBarIsVisible" Value="True" />
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <Tab Route="Home" Title="首页">
        <Tab.Icon>
            <FontImageSource
                FontFamily="MaterialOutlined"
                Glyph="{x:Static material:MaterialOutlined.Home}"
                Size="24" />
        </Tab.Icon>
        <ShellContent ContentTemplate="{DataTemplate views:HomePage}" Route="DashboardPage" />
    </Tab>

    <Tab Route="Settings" Title="设置">
        <Tab.Icon>
            <FontImageSource
                FontFamily="MaterialOutlined"
                Glyph="{x:Static material:MaterialOutlined.Settings}"
                Size="24" />
        </Tab.Icon>
        <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" Route="DashboardPage" />
    </Tab>

    <Tab Route="Profile" Title="我的">
        <Tab.Icon>
            <FontImageSource
                FontFamily="MaterialOutlined"
                Glyph="{x:Static material:MaterialOutlined.Person}"
                Size="24" />
        </Tab.Icon>
        <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" Route="DashboardPage" />
    </Tab>

</Shell>